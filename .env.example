# --- Database -----------------------------------------------------------
# Local dev: compose maps PostGIS to host port 5433
DATABASE_URL=postgresql+psycopg://uae:uae@localhost:5433/uaealive

# --- AI (LiteLLM proxy) ---------------------------------------------------
# The real key is NEVER committed and NEVER sent to the browser.
LITELLM_BASE_URL=https://your-litellm-proxy.example.com
LITELLM_API_KEY=sk-replace-me
AI_MODEL_CHAT=claude-account-haiku-4-5
AI_MODEL_COPILOT=claude-account-sonnet-4-6

# --- Admin ---------------------------------------------------------------
ADMIN_PASSWORD=change-me-strong-password

# --- CORS / Frontend -----------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8000
